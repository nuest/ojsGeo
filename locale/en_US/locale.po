msgstr "Search"

msgid "plugins.generic.geoMetadata.map.geocoder.errorMessage"
msgstr "Nothing found."

msgid "plugins.generic.geoMetadata.map.geocoder.buttonTitle"
msgstr "Search on the map"

msgid "plugins.generic.geoMetadata.map.draw.actionCancelTitle"
msgstr "Cancel drawing"

msgid "plugins.generic.geoMetadata.map.draw.actionCancel"
msgstr "Cancel"

msgid "plugins.generic.geoMetadata.map.draw.finishTitle"
msgstr "Finish drawing"

msgid "plugins.generic.geoMetadata.map.draw.finish"
msgstr "Finish"

msgid "plugins.generic.geoMetadata.map.draw.undoTitle"
msgstr "Delete last point drawn"

msgid "plugins.generic.geoMetadata.map.draw.undo"
msgstr "Delete last point"

msgid "plugins.generic.geoMetadata.map.draw.polyline"
msgstr "Draw a polyline"

msgid "plugins.generic.geoMetadata.map.draw.polygon"
msgstr "Draw a polygon"

msgid "plugins.generic.geoMetadata.map.draw.rectangle"
