msgstr "Zoom in"

msgid "plugins.generic.geoMetadata.map.zoom.out"
msgstr "Zoom out"

msgid "plugins.generic.geoMetadata.map.resetView.title"
msgstr "Reset view"

msgid "plugins.generic.geoMetadata.map.overlap.prevTitle"
msgstr "Previous article"

msgid "plugins.generic.geoMetadata.map.overlap.nextTitle"
msgstr "Next article"

msgid "plugins.generic.geoMetadata.map.overlap.counter"
msgstr "{$i} of {$n} articles"

